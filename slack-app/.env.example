SLACK_SIGNING_SECRET=
SLACK_BOT_TOKEN=xoxb-
ANTHROPIC_API_KEY=sk-ant-
ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# Local server port for the Slack app.
SUMMIT_DIGEST_SLACK_PORT=8787

# Default issue to clone when Audrey does not pass prev=...
SUMMIT_DIGEST_PREVIOUS_ISSUE=2026-05-25-audrey-a

# Public production base used in Slack messages.
SUMMIT_DIGEST_PUBLIC_BASE_URL=https://summit-house-digest-prototype.netlify.app

# Optional channel ID for final share. If empty, the app posts final status where it was invoked.
SUMMIT_DIGEST_SHARE_CHANNEL=

# Slack context lookback for draft candidate generation.
SUMMIT_DIGEST_CONTEXT_LOOKBACK_DAYS=7

# Keep false during setup. Set true only when Netlify auth is configured for the runtime.
SUMMIT_DIGEST_ENABLE_DEPLOY=false

